#!/usr/bin/env bash
# ============================================================
#  Aegis ICS — One-Click Launcher
#  Usage:
#    ./aegis            Interactive menu
#    ./aegis v1         Start Version 1 stack
#    ./aegis v2         Start Version 2 stack
#    ./aegis stop       Stop all Aegis services
#    ./aegis test       Run all test suites
#    ./aegis setup      Install dependencies only
# ============================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PIDFILE="$SCRIPT_DIR/.aegis.pids"
VENV_DIR="$SCRIPT_DIR/.venv"

# ── Colors ──────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

log()  { echo -e "${GREEN}[✓]${NC} $*"; }
warn() { echo -e "${YELLOW}[!]${NC} $*"; }
err()  { echo -e "${RED}[✗]${NC} $*" >&2; }
info() { echo -e "${CYAN}[→]${NC} $*"; }

banner() {
    echo -e "${CYAN}"
    echo "  ╔═══════════════════════════════════════════════════╗"
    echo "  ║         AEGIS ICS — SERVICE LAUNCHER              ║"
    echo "  ║   Zero-Trust ICS/OT Security Platform             ║"
    echo "  ╚═══════════════════════════════════════════════════╝"
    echo -e "${NC}"
}

# ── Dependency Checks ───────────────────────────────────────
check_python() {
    local py=""
    for candidate in python3 python; do
        if command -v "$candidate" &>/dev/null; then
            py="$candidate"
            break
        fi
    done
    if [ -z "$py" ]; then
        err "Python 3 is required but not found. Install it first."
        exit 1
    fi
    echo "$py"
}

check_mosquitto() {
    if ! command -v mosquitto &>/dev/null; then
        warn "Mosquitto MQTT broker not found."
        warn "Install it: sudo apt install mosquitto  (Debian/Ubuntu)"
        warn "            sudo dnf install mosquitto   (Fedora/RHEL)"
        warn "Continuing without broker — telemetry won't flow over MQTT."
        return 1
    fi
    return 0
}

# ── Virtual Environment ─────────────────────────────────────
setup_venv() {
    local py="$1"
    if [ ! -d "$VENV_DIR" ]; then
        info "Creating Python virtual environment..."
        "$py" -m venv "$VENV_DIR"
    fi

    info "Installing V1 dependencies..."
    "$VENV_DIR/bin/pip" install --quiet -r "$SCRIPT_DIR/server/api/requirements.txt"

    info "Installing V2 dependencies..."
    "$VENV_DIR/bin/pip" install --quiet -r "$SCRIPT_DIR/version-two/requirements.txt"

    log "All dependencies installed."
}

# ── Certificate Generation ──────────────────────────────────
generate_certs() {
    if [ -f "$SCRIPT_DIR/certs/root-ca.crt" ]; then
        log "TLS certificates already exist."
        return 0
    fi
    info "Generating TLS certificates..."
    "$VENV_DIR/bin/python" "$SCRIPT_DIR/certs/generate_certs.py" \
        --out-dir "$SCRIPT_DIR/certs" \
        --device-id ESP32_001 --device-id ESP32_002
    log "TLS certificates generated."
}

# ── Environment File ────────────────────────────────────────
setup_env() {
    if [ -f "$SCRIPT_DIR/.env" ]; then
        log ".env file exists."
        return 0
    fi
    info "Creating .env from template..."
    cp "$SCRIPT_DIR/.env.example" "$SCRIPT_DIR/.env"
    # Generate a random secret key
    local secret
    secret=$("$VENV_DIR/bin/python" -c "import os; print(os.urandom(24).hex())")
    sed -i "s/^FLASK_SECRET_KEY=.*/FLASK_SECRET_KEY=$secret/" "$SCRIPT_DIR/.env"
    sed -i "s/^DEVICE_KEY_ESP32_001=.*/DEVICE_KEY_ESP32_001=$(openssl rand -hex 16 2>/dev/null || echo 'dev_key_001')/" "$SCRIPT_DIR/.env"
    sed -i "s/^DEVICE_KEY_ESP32_002=.*/DEVICE_KEY_ESP32_002=$(openssl rand -hex 16 2>/dev/null || echo 'dev_key_002')/" "$SCRIPT_DIR/.env"
    log ".env created with generated secrets."
}

# ── .env Loader ─────────────────────────────────────────────
load_env() {
    if [ -f "$SCRIPT_DIR/.env" ]; then
        set -o allexport
        source "$SCRIPT_DIR/.env"
        set +o allexport
    fi
}

# ── Process Management ──────────────────────────────────────
save_pid() {
    echo "$1:$2" >> "$PIDFILE"
}

stop_all() {
    if [ ! -f "$PIDFILE" ]; then
        warn "No running Aegis services found."
        return 0
    fi
    info "Stopping Aegis services..."
    while IFS=: read -r name pid; do
        if kill -0 "$pid" 2>/dev/null; then
            kill "$pid" 2>/dev/null && log "Stopped $name (PID $pid)" || warn "Failed to stop $name (PID $pid)"
        fi
    done < "$PIDFILE"
    rm -f "$PIDFILE"
    log "All services stopped."
}

open_browser() {
    local url="$1"
    sleep 2
    if command -v xdg-open &>/dev/null; then
        xdg-open "$url" 2>/dev/null &
    elif command -v open &>/dev/null; then
        open "$url" 2>/dev/null &
    else
        info "Open your browser to: $url"
    fi
}

# ── Start Version 1 ─────────────────────────────────────────
start_v1() {
    log "Starting Aegis Version 1.0.0"
    load_env

    # MQTT Broker
    if check_mosquitto; then
        info "Starting Mosquitto broker..."
        mosquitto -c "$SCRIPT_DIR/server/mqtt_broker/mosquitto.conf" -d 2>/dev/null || \
            mosquitto -d 2>/dev/null || warn "Mosquitto failed to start — continuing without broker."
        local mqtt_pid
        mqtt_pid=$(pgrep -n mosquitto 2>/dev/null || echo "")
        [ -n "$mqtt_pid" ] && save_pid "mosquitto" "$mqtt_pid"
    fi

    # Flask API Server
    info "Starting V1 API server on http://127.0.0.1:5000..."
    cd "$SCRIPT_DIR"
    "$VENV_DIR/bin/python" -m server.api.app &
    save_pid "v1-server" "$!"

    # ESP32 Simulator
    info "Starting ESP32 simulator..."
    "$VENV_DIR/bin/python" "$SCRIPT_DIR/esp32_sim/simulator.py" \
        --config "$SCRIPT_DIR/esp32_sim/device_config.json" &
    save_pid "v1-simulator" "$!"

    log "Version 1 stack is running."
    open_browser "http://127.0.0.1:5000"
}

# ── Start Version 2 ─────────────────────────────────────────
start_v2() {
    log "Starting Aegis Version 2.0.0 (Stuxnet-Proof Build)"
    load_env

    # MQTT Broker (plain mode for V2)
    if check_mosquitto; then
        info "Starting Mosquitto broker..."
        mosquitto -d 2>/dev/null || warn "Mosquitto failed to start."
        local mqtt_pid
        mqtt_pid=$(pgrep -n mosquitto 2>/dev/null || echo "")
        [ -n "$mqtt_pid" ] && save_pid "mosquitto" "$mqtt_pid"
    fi

    # V2 Flask SCADA Server
    info "Starting V2 SCADA server on http://127.0.0.1:5000..."
    cd "$SCRIPT_DIR/version-two"
    "$VENV_DIR/bin/python" app.py &
    save_pid "v2-server" "$!"

    # V2 Device Simulator
    info "Starting V2 device simulator..."
    "$VENV_DIR/bin/python" simulator.py &
    save_pid "v2-simulator" "$!"

    cd "$SCRIPT_DIR"
    log "Version 2 stack is running."
    echo ""
    info "Login credentials:  admin / admin"
    info "Dashboard:          http://127.0.0.1:5000"
    open_browser "http://127.0.0.1:5000"
}

# ── Run Tests ────────────────────────────────────────────────
run_tests() {
    info "Running Version 1 test suite..."
    cd "$SCRIPT_DIR"
    "$VENV_DIR/bin/python" -m unittest discover -s tests -v
    echo ""
    info "Running Version 2 test suite..."
    "$VENV_DIR/bin/python" -m unittest discover -s version-two -v
    log "All tests complete."
}

# ── Interactive Menu ─────────────────────────────────────────
menu() {
    banner
    echo "  Select an option:"
    echo ""
    echo -e "    ${BOLD}1${NC}  Start Version 1  (Zero-Trust OT, TLS, Trust Engine)"
    echo -e "    ${BOLD}2${NC}  Start Version 2  (Stuxnet-Proof SCADA, SQL Auditing)"
    echo -e "    ${BOLD}3${NC}  Run all tests"
    echo -e "    ${BOLD}4${NC}  Stop all running services"
    echo -e "    ${BOLD}5${NC}  Setup only (install deps, generate certs)"
    echo -e "    ${BOLD}q${NC}  Exit"
    echo ""
    read -rp "  → " choice

    case "$choice" in
        1) start_v1 ;;
        2) start_v2 ;;
        3) run_tests ;;
        4) stop_all ;;
        5) log "Setup complete." ;;
        q|Q) exit 0 ;;
        *) err "Invalid option."; exit 1 ;;
    esac
}

# ── Main ─────────────────────────────────────────────────────
main() {
    cd "$SCRIPT_DIR"

    # Always ensure venv + deps are ready
    local py
    py=$(check_python)
    setup_venv "$py"
    generate_certs 2>/dev/null || true
    setup_env

    case "${1:-}" in
        v1)    start_v1 ;;
        v2)    start_v2 ;;
        stop)  stop_all ;;
        test)  run_tests ;;
        setup) log "Setup complete." ;;
        *)     menu ;;
    esac
}

main "$@"
