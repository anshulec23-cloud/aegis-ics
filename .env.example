# Local Ollama server used by the dashboard AI query endpoint.
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b

# MQTT broker settings for telemetry and control traffic.
MQTT_HOST=127.0.0.1
MQTT_PORT=8883
MQTT_USE_TLS=true
MQTT_CA_CERT=certs/root-ca.crt
MQTT_USERNAME=
MQTT_PASSWORD=

# Flask session secret. Keep this out of git and rotate it if exposed.
FLASK_SECRET_KEY=

# HMAC signing keys for simulated devices.
DEVICE_KEY_ESP32_001=
DEVICE_KEY_ESP32_002=
